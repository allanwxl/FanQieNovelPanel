{
  "manifest_version": 3,
  "name": "番茄短故事数据面板",
  "description": "本地优先的番茄短故事数据增强面板，只读聚合作者自己的作品数据。支持批量对比所有短篇作品的曝光、阅读、触底等核心指标，智能筛选高潜力爆款作品，辅助精准运营推广决策。所有数据仅存储在本地浏览器，不上传任何服务器。",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://fanqienovel.com/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "番茄短故事数据面板",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "categories": ["productivity", "developer tools"],
  "short_name": "番茄短故事面板"
}
